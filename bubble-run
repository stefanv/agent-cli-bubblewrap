#!/bin/bash
# Modified from https://patrickmccanna.net/a-better-way-to-limit-claude-code-and-other-coding-agents-access-to-secrets/

ALLOW_RW=(
    "$PWD"
    "$HOME/.npm"
)

ALLOW_RO=(
    /usr
    /lib
    /lib64
    /bin
    /usr/libexec
    /etc/resolv.conf
    /etc/nsswitch.conf
    /etc/hosts
    /etc/ssl
    /etc/crypto-policies
    /etc/pki
    /etc/passwd
    /etc/group
    /run/systemd/resolve
    "$HOME/.gitconfig"
    "$HOME/.local"
    "$HOME/src/dotfiles"
    "$HOME/.npmrc"
    "$HOME/.npm-packages"
    "$HOME/.bun"
)

if [[ -n "$AGENT_BUBBLE_RW" ]]; then
    IFS=':' read -ra _extra <<< "$AGENT_BUBBLE_RW"
    ALLOW_RW+=("${_extra[@]}")
fi
if [[ -n "$AGENT_BUBBLE_RO" ]]; then
    IFS=':' read -ra _extra <<< "$AGENT_BUBBLE_RO"
    ALLOW_RO+=("${_extra[@]}")
fi

# List of files or directories to be masked with /dev/null
BANNED=(
    ".env"
    ".env.local"
    ".env.production"
)

ALLOW_RW_ARGS=()
for item in "${ALLOW_RW[@]}"; do
    ALLOW_RW_ARGS+=(--bind "$item" "$item")
done

ALLOW_RO_ARGS=()
for item in "${ALLOW_RO[@]}"; do
    ALLOW_RO_ARGS+=(--ro-bind "$item" "$item")
done

if [[ -n "$AGENT_BUBBLE_BANNED" ]]; then
    IFS=':' read -ra _extra <<< "$AGENT_BUBBLE_BANNED"
    BANNED+=("${_extra[@]}")
fi

BANNED_ARGS=()
for item in "${BANNED[@]}"; do
    [[ -e "$PWD/$item" ]] && BANNED_ARGS+=(--ro-bind /dev/null "$PWD/$item")
done

# Intercept and translate shorthand flags (-y, -c) for the command
PROCESSED_ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --)
            shift
            CMD="$1"
            shift
            CMD_ARGS=()
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    -y) [[ -n "$AGENT_YOLO_FLAG" ]] && CMD_ARGS+=("$AGENT_YOLO_FLAG") || CMD_ARGS+=("-y") ;;
                    -c) [[ -n "$AGENT_COMMIT_FLAG" ]] && CMD_ARGS+=("$AGENT_COMMIT_FLAG") || CMD_ARGS+=("-c") ;;
                    *) CMD_ARGS+=("$1") ;;
                esac
                shift
            done
            PROCESSED_ARGS+=(-- "$CMD" "${CMD_ARGS[@]}")
            break
            ;;
        *)
            PROCESSED_ARGS+=("$1")
            shift
            ;;
    esac
done
set -- "${PROCESSED_ARGS[@]}"

exec bwrap \
     "${ALLOW_RW_ARGS[@]}" \
     "${ALLOW_RO_ARGS[@]}" \
     --tmpfs /tmp \
     --proc /proc \
     --dev /dev \
     --share-net \
     --unshare-pid \
     --die-with-parent \
     "${BANNED_ARGS[@]}" \
     "$@"
