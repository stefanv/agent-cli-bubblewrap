#!/bin/bash
# Modified from https://patrickmccanna.net/a-better-way-to-limit-claude-code-and-other-coding-agents-access-to-secrets/

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    if [[ -n "${AGENT_NAME:-}" ]]; then
        cat <<EOF
Usage: $AGENT_NAME [bwrap-options] [-h] [-- <$AGENT_CLI options>]

Run $AGENT_CLI inside a bubblewrap sandbox.

Flags (place before --):
  -y    YOLO mode (maps to: $AGENT_YOLO_FLAG)
  -c    Continue the most recent session (maps to: $AGENT_CONTINUE_FLAG)
  -h    Show this help

Any bwrap flags (e.g. --unsetenv, --bind) may also be placed before --.
Everything after -- is passed as-is to $AGENT_CLI.

Environment variables (colon-separated paths, appended to defaults):
  AGENT_BUBBLE_RW      Extra read-write paths
  AGENT_BUBBLE_RO      Extra read-only paths
  AGENT_BUBBLE_BANNED  Extra paths to block

Environment variables are inherited from the parent process. To hide
specific variables from the sandbox, pass bwrap flags via bubble-run:
  bubble-run --unsetenv SECRET_TOKEN -- $AGENT_CLI
  bubble-run --clearenv --setenv PATH "\$PATH" -- $AGENT_CLI
EOF
    else
        cat <<EOF
Usage: bubble-run [bwrap-options] -- <command> [args]

Low-level bwrap wrapper. Prefer claude-bubble, gemini-bubble, etc. for agent use.

Default sandbox:
  Read-write: \$PWD, \$HOME/.npm
  Read-only:  /usr, /lib, /bin, /etc/ssl, ~/.gitconfig, ~/.local, ...
  Blocked:    .env, .env.local, .env.production
  Network:    shared (--share-net)
  PID ns:     isolated (--unshare-pid)

Environment variables are inherited from the parent process. To hide
specific variables from the sandbox, pass bwrap flags before --:
  bubble-run --unsetenv SECRET_TOKEN -- <command>
  bubble-run --clearenv --setenv PATH "\$PATH" -- <command>
EOF
    fi
    exit 0
fi

ALLOW_RW=(
    "$PWD"
    "$HOME/.npm"
)

ALLOW_RO=(
    /usr
    /lib
    /lib64
    /bin
    /usr/libexec
    /etc/resolv.conf
    /etc/nsswitch.conf
    /etc/hosts
    /etc/ssl
    /etc/crypto-policies
    /etc/pki
    /etc/passwd
    /etc/group
    /run/systemd/resolve
    "$HOME/.gitconfig"
    "$HOME/.local"
    "$HOME/src/dotfiles"
    "$HOME/.npmrc"
    "$HOME/.npm-packages"
    "$HOME/.bun"
)

if [[ -n "$AGENT_BUBBLE_RW" ]]; then
    IFS=':' read -ra _extra <<< "$AGENT_BUBBLE_RW"
    ALLOW_RW+=("${_extra[@]}")
fi
if [[ -n "$AGENT_BUBBLE_RO" ]]; then
    IFS=':' read -ra _extra <<< "$AGENT_BUBBLE_RO"
    ALLOW_RO+=("${_extra[@]}")
fi

# List of files or directories to be masked with /dev/null
BANNED=(
    ".env"
    ".env.local"
    ".env.production"
)

ALLOW_RW_ARGS=()
for item in "${ALLOW_RW[@]}"; do
    ALLOW_RW_ARGS+=(--bind "$item" "$item")
done

ALLOW_RO_ARGS=()
for item in "${ALLOW_RO[@]}"; do
    ALLOW_RO_ARGS+=(--ro-bind "$item" "$item")
done

if [[ -n "$AGENT_BUBBLE_BANNED" ]]; then
    IFS=':' read -ra _extra <<< "$AGENT_BUBBLE_BANNED"
    BANNED+=("${_extra[@]}")
fi

BANNED_ARGS=()
for item in "${BANNED[@]}"; do
    [[ -e "$PWD/$item" ]] && BANNED_ARGS+=(--ro-bind /dev/null "$PWD/$item")
done

BWRAP_PASSTHROUGH=()
CMD_FLAGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        -y) if [[ -n "${AGENT_YOLO_FLAG:-}" ]]; then
                CMD_FLAGS+=("$AGENT_YOLO_FLAG")
            elif [[ -z "${AGENT_YOLO_FLAG+x}" ]]; then
                CMD_FLAGS+=("-y")
            fi
            shift ;;
        -c) if [[ -n "$AGENT_CONTINUE_FLAG" ]]; then
                read -ra _cf <<< "$AGENT_CONTINUE_FLAG"
                CMD_FLAGS+=("${_cf[@]}")
            else
                CMD_FLAGS+=("-c")
            fi
            shift ;;
        --) shift; break ;;
        *) BWRAP_PASSTHROUGH+=("$1"); shift ;;
    esac
done
CMD="$1"; shift

exec bwrap \
     "${ALLOW_RW_ARGS[@]}" \
     "${ALLOW_RO_ARGS[@]}" \
     --tmpfs /tmp \
     --proc /proc \
     --dev /dev \
     --share-net \
     --unshare-pid \
     --die-with-parent \
     "${BANNED_ARGS[@]}" \
     "${BWRAP_PASSTHROUGH[@]}" \
     -- \
     "$CMD" "${CMD_FLAGS[@]}" "$@"
