#!/bin/bash

export AGENT_NAME="gemini-bubble"
export AGENT_CLI="gemini"
export AGENT_YOLO_FLAG="--approval-mode=yolo"
export AGENT_CONTINUE_FLAG="--resume latest"

EXTRA_BWRAP_ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) exec "$(dirname "$0")/bubble-run" --help ;;
        --) shift; break ;;
        *) EXTRA_BWRAP_ARGS+=("$1"); shift ;;
    esac
done

ALLOW_RW=(
    "$HOME/.gemini"
)

ALLOW_RO=(
    "$HOME/.npm-packages"
)

BANNED=(
)

ALLOW_RW_ARGS=()
for item in "${ALLOW_RW[@]}"; do
    ALLOW_RW_ARGS+=(--bind "$item" "$item")
done

ALLOW_RO_ARGS=()
for item in "${ALLOW_RO[@]}"; do
    ALLOW_RO_ARGS+=(--ro-bind "$item" "$item")
done

BANNED_ARGS=()
for item in "${BANNED[@]}"; do
    BANNED_ARGS+=(--ro-bind /dev/null "$PWD/$item")
done

exec "$(dirname "$0")/bubble-run" \
     "${ALLOW_RW_ARGS[@]}" \
     "${ALLOW_RO_ARGS[@]}" \
     "${BANNED_ARGS[@]}" \
     "${EXTRA_BWRAP_ARGS[@]}" \
     -- \
     "$(command -v gemini)" "$@"
